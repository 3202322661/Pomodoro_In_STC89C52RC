   9           */
  10          #include "config.h"
  11          #include "buzzer.h"
  12          
  13          static void DelayMS(unsigned int ms)
  14          {
  15   1        unsigned int i, j;
  16   1        for (i = ms; i > 0; i--)
  17   1        {
  18   2          for (j = 110; j> 0; j--);
  19   2        }
  20   1      }
  21          
  22          void Beep_Alarm() 
  23          {
  24   1        unsigned int i, j;
  25   1        for (j = 0; j < 5; j++) 
  26   1        {
  27   2          for (i = 0; i < 300; i++) 
  28   2          {
  29   3            BUZZER = 1;
  30   3            DelayMS(1);
  31   3            BUZZER = 0;
  32   3            DelayMS(1);
  33   3          }
  34   2          
  35   2          DelayMS(100);
  36   2        }
  37   1        
  38   1        BUZZER = 0;
  39   1      }


