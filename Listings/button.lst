   1          /**
   2           * button.c - 按键扫描模块
   3           *
   4           * 三个独立按键, 10ms 消抖, 按下后等待释放 (阻塞式)。
   5           * 按键优先级: KEY_SET > KEY_ADD > KEY_START_STOP
   6           *
   7           * 硬件: P3.2(设置), P3.3(启停), P3.4(递加), 均为低电平有效。
   8           */
   9          
  10          #include "config.h"
  11          #include "button.h"
  12          
  13          /**
  14           * DelayMS - 毫秒级延时 (基于指令周期粗略估算)
  15           *   适用于 11.0592MHz / 12T 模式。
  16           *   精确度 ≈ ±10%, 对按键消抖而言足够。
  17           */
  18          static void DelayMS(unsigned int ms)
  19          {
  20   1        unsigned int i, j;
  21   1        for (i = ms; i > 0; i--)
  22   1        {
  23   2          for (j = 110; j> 0; j--);
  24   2        }
  25   1      }
  26          
  27          /**
  28           * Button_Scan - 扫描三个按键 (阻塞式消抖)
  29           *
  30           * 消抖流程:
  31           *   1. 检测低电平
  32           *   2. 延时 10ms
  33           *   3. 复检低电平 (消抖确认)
  34           *   4. 等待按键释放 (防止连发)
  35           *   5. 返回按键 ID
  36           *
  37           * 返回值:
  38           *   BTN_SET   — KEY_SET 按下
  39           *   BTN_START — KEY_START_STOP 按下
  40           *   BTN_ADD   — KEY_ADD 按下
  41           *   BTN_NONE  — 无按键按下
  42           */
  43          unsigned char Button_Scan()
  44          {
  45   1        if (KEY_SET == 0)
  46   1        {
  47   2          DelayMS(10);
  48   2          if (KEY_SET == 0)
  49   2          {
  50   3            while (KEY_SET == 0);
  51   3            return BTN_SET;
  52   3          }
  53   2        }
  54   1        
